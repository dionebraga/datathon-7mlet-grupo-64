# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.installed.cfg
*.egg

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/
.python-version

# ---- Testing / coverage ----
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.mypy_cache/
.ruff_cache/

# ---- Jupyter ----
.ipynb_checkpoints/

# ---- MLflow / experiment tracking ----
mlruns/
mlartifacts/
