# ---- Secrets / environment ----
.env
.env.*
!.env.example
*.key
*.pem
secrets/

# ---- Kaggle credentials ----
kaggle.json
.kaggle/

# ---- Data (large / generated artifacts are NOT versioned) ----
# We version small documented descriptors (README, schema, golden set) but never
# raw downloads, generated tables, provenance or big binaries.
data/kaggle/raw/
data/**/*.parquet
data/**/*.zip
data/**/*.csv
data/**/*.json
!data/**/schema*.json
!data/golden_set/*.jsonl
!data/**/*.md
# Generated artifacts of the run
artifacts/
*.joblib
*.pkl
*.pt
*.pth
*.onnx

# ---- OS / editor ----
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
