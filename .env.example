# =============================================================================
# .env.example — Adaptive Offers Platform (datathon-7mlet-grupo-74)
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# No real customer data, identifiers, income or protected attributes are used.
# =============================================================================

# ---- Runtime ----
APP_ENV=local                       # local | dev | staging | prod
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
RANDOM_SEED=42                      # global seed for reproducibility

# ---- Paths (override only if you relocate the data layer) ----
DATA_DIR=data
ARTIFACTS_DIR=artifacts

# ---- MLflow experiment tracking ----
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=adaptive-offers
MLFLOW_ALLOW_FILE_STORE=true        # opt back into the file:./mlruns backend (MLflow 3.x)

# ---- Bandit / policy defaults ----
POLICY_DEFAULT=thompson            # baseline | thompson | nilos_ucb | linucb
POLICY_VERSION=v1
EXPLORATION_FLOOR=0.02             # minimum exploration probability (guardrail)

# ---- LLM assistant (OPTIONAL). If unset, an offline deterministic summarizer is used. ----
LLM_PROVIDER=offline               # offline | anthropic | azure_openai
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ---- Azure OpenAI (target architecture; optional locally) ----
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# ---- Azure platform references (documented in docs/architecture-azure.md) ----
AZURE_KEY_VAULT_URI=
AZURE_STORAGE_ACCOUNT=
AZURE_APP_INSIGHTS_CONNECTION_STRING=

# ---- Kaggle (only needed to download the REAL factual base; see data/kaggle/README.md) ----
KAGGLE_USERNAME=
KAGGLE_KEY=

# ---- API service ----
API_HOST=0.0.0.0
API_PORT=8000
